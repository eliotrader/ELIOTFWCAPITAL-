{
  "rewrites": [
    { "source": "/.netlify/functions/claude", "destination": "/api/claude" },
    { "source": "/.netlify/functions/market-data", "destination": "/api/market-data" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:;"
        }
      ]
    }
  ]
}